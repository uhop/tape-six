{
  "name": "tape-six",
  "version": "1.7.12",
  "description": "TAP-based unit test library for Node, Deno, Bun, and browsers. ES modules, TypeScript, zero dependencies.",
  "type": "module",
  "main": "index.js",
  "module": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": "./index.js",
    "./bin/*": "./bin/*",
    "./*": "./src/*"
  },
  "bin": {
    "tape6": "bin/tape6.js",
    "tape6-node": "bin/tape6-node.js",
    "tape6-bun": "bin/tape6-bun.js",
    "tape6-deno": "bin/tape6-deno.js",
    "tape6-seq": "bin/tape6-seq.js",
    "tape6-server": "bin/tape6-server.js",
    "tape6-runner": "bin/tape6-runner.js"
  },
  "scripts": {
    "start": "node bin/tape6-server.js --trace",
    "copyDeep6": "node scripts/copyFolder.js --src ./vendors/deep6/src --dst ./src/deep6 --clear",
    "build": "npm run copyDeep6",
    "prepublishOnly": "npm run build",
    "lint": "prettier --check .",
    "lint:fix": "prettier --write .",
    "test": "node ./bin/tape6.js --flags FO",
    "test:bun": "bun run ./bin/tape6-bun.js --flags FO",
    "test:deno": "deno run -A ./bin/tape6-deno.js --flags FO",
    "test:seq": "node ./bin/tape6-seq.js --flags FO",
    "test:seq:bun": "bun run ./bin/tape6-seq.js --flags FO",
    "test:seq:deno": "deno run -A ./bin/tape6-seq.js --flags FO",
    "ts-test": "node ./bin/tape6.js --flags FO 'tests/test-*.*ts'",
    "ts-test:bun": "bun run ./bin/tape6-bun.js --flags FO 'tests/test-*.*ts'",
    "ts-test:deno": "deno run -A ./bin/tape6-deno.js --flags FO 'tests/test-*.*ts'",
    "ts-check": "tsc --noEmit"
  },
  "github": "http://github.com/uhop/tape-six",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uhop/tape-six.git"
  },
  "keywords": [
    "tap",
    "test",
    "harness",
    "assert",
    "browser",
    "unit-test",
    "testing",
    "test-runner",
    "esm",
    "es-modules",
    "typescript",
    "deno",
    "bun",
    "nodejs",
    "tap-protocol",
    "cross-runtime",
    "zero-dependency"
  ],
  "author": "Eugene Lazutkin <eugene.lazutkin@gmail.com> (https://www.lazutkin.com/)",
  "funding": "https://github.com/sponsors/uhop",
  "license": "BSD-3-Clause",
  "bugs": {
    "url": "https://github.com/uhop/tape-six/issues"
  },
  "homepage": "https://github.com/uhop/tape-six#readme",
  "llms": "https://raw.githubusercontent.com/uhop/tape-six/master/llms.txt",
  "llmsFull": "https://raw.githubusercontent.com/uhop/tape-six/master/llms-full.txt",
  "files": [
    "index.*",
    "bin",
    "web-app",
    "src",
    "llms.txt",
    "llms-full.txt",
    "TESTING.md",
    "skills"
  ],
  "tape6": {
    "tests": [
      "/tests/test-*.js",
      "/tests/test-*.mjs"
    ],
    "cli": [
      "/tests/test-*.cjs"
    ],
    "browser": [
      "/tests/browser/test-*.html"
    ],
    "importmap": {
      "imports": {
        "tape-six": "../index.js",
        "tape-six/": "../src/",
        "chai": "../node_modules/chai/index.js"
      }
    }
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/node": "^25.5.0",
    "chai": "^6.2.2",
    "typescript": "^5.9.3"
  }
}
